{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "cd ${workspaceFolder}/build && cmake .. && make -j$(nproc)",
            "args": [],
            "problemMatcher": {
                "owner": "cuda",
                "fileLocation": "absolute",
                "pattern": {
                    "regexp": "^(.*?):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "clean build",
            "type": "shell",
            "command": "cd ${workspaceFolder}/build && rm -rf * && cmake .. && make -j$(nproc)",
            "args": [],
            "problemMatcher": {
                "owner": "cuda",
                "fileLocation": "absolute",
                "pattern": {
                    "regexp": "^(.*?):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}