{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "yolo8Test",
            "type": "cppdbg",
            "request": "launch",
            "program": "/work/cuda/yolo8Test/cpp/build/yolov8_trt",
            "args": [],
            "stopAtEntry": false,
            "cwd": "/work/cuda/yolo8Test/cpp",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "CUDA C++: Launch",
            "type": "cuda-gdb",
            "request": "launch",
            "program": "/work/cuda/src/Kernel/build/preprocess_test",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "miDebuggerPath": "/usr/local/cuda-12.1/bin/cuda-gdb",
            "miDebuggerArgs": "-q -x /work/cuda/.gdbinit",
            "environment": [
                { "name": "DISPLAY", "value": ":0" },
                { "name": "LD_LIBRARY_PATH", "value": "/usr/local/cuda-12.1/lib64" },
                { "name": "CUDA_VISIBLE_DEVICES", "value": "0" }
            ]
        },
        {
            "name": "CUDA Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/cuda_demo", // 你的可执行文件路径
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/local/cuda-12.1/bin/cuda-gdb", // 关键：指定 cuda-gdb
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build" // 调试前先编译
        }
    ]
}